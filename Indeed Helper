            .screener-status.loading::before { background: var(--yellow); animation: pulse 1.2s ease-in-out infinite; }
            @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.35} }

            /* ── Score card ── */
            .score-card {
                display: flex; align-items: center; justify-content: space-between;
                padding: 14px 16px; margin-bottom: 12px;
                background: var(--bg2); border: 1px solid var(--border2);
                border-radius: var(--radius); position: relative; overflow: hidden;
            }
            .score-card::after {
                content: ''; position: absolute; inset: 0;
                background: linear-gradient(135deg, transparent 60%, rgba(47,129,247,.04));
                pointer-events: none;
            }
            .score-left { display: flex; flex-direction: column; }
            .score-label {
                font-size: 9px; font-weight: 700; letter-spacing: 1.2px;
                text-transform: uppercase; color: var(--text2); margin-bottom: 4px;
            }
            .score-value {
                font-family: 'JetBrains Mono', monospace; font-size: 52px; font-weight: 700;
                line-height: 1; letter-spacing: -3px; transition: color .3s, text-shadow .3s;
                color: var(--text2);
            }
            .score-value.elite  { color: var(--green); text-shadow: 0 0 24px rgba(63,185,80,.4); }
            .score-value.review { color: var(--yellow); text-shadow: 0 0 24px rgba(210,153,34,.35); }
            .score-value.maybe  { color: var(--red); }
            .score-value.reject { color: var(--text2); }
            .score-tier {
                font-size: 10px; font-weight: 700; letter-spacing: .6px; text-transform: uppercase;
                padding: 4px 10px; border-radius: 20px; display: inline-block; margin-top: 6px;
                transition: all .3s;
            }
            .score-tier.elite  { background: var(--green-dim); color: var(--green); border: 1px solid var(--green-border); }
            .score-tier.review { background: var(--yellow-dim); color: var(--yellow); border: 1px solid var(--yellow-border); }
            .score-tier.maybe  { background: var(--red-dim); color: var(--red); border: 1px solid var(--red-border); }
            .score-tier.reject { background: var(--bg3); color: var(--text2); border: 1px solid var(--border); }
            .score-right { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }
            .score-meta  { font-size: 9px; color: var(--text2); text-align: right; line-height: 1.5; }

            /* ── Breakdown ── */
            .breakdown-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 12px; }
            .breakdown-col { display: flex; flex-direction: column; min-height: 0; }
            .breakdown-header {
                display: flex; align-items: center; gap: 5px;
                font-size: 10px; font-weight: 700; letter-spacing: .5px; text-transform: uppercase;
                padding: 7px 10px; border-radius: var(--radius-sm) var(--radius-sm) 0 0;
            }
            .breakdown-header.pos {
                background: var(--green-dim); color: var(--green);
                border: 1px solid var(--green-border); border-bottom: none;
            }
            .breakdown-header.neg {
                background: var(--red-dim); color: var(--red);
                border: 1px solid var(--red-border); border-bottom: none;
            }
            .breakdown-header .bh-dot {
                width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
            }
            .breakdown-header.pos .bh-dot { background: var(--green); }
            .breakdown-header.neg .bh-dot { background: var(--red); }
            .breakdown-list { overflow-y: auto; max-height: 240px; padding: 6px; border-radius: 0 0 var(--radius-sm) var(--radius-sm); }
            .breakdown-list.pos { background: rgba(63,185,80,.03); border: 1px solid var(--green-border); border-top: none; }
            .breakdown-list.neg { background: rgba(248,81,73,.03); border: 1px solid var(--red-border); border-top: none; }
            .breakdown-list::-webkit-scrollbar { width: 3px; }
            .breakdown-list::-webkit-scrollbar-track { background: transparent; }
            .breakdown-list.pos::-webkit-scrollbar-thumb { background: rgba(63,185,80,.35); border-radius: 2px; }
            .breakdown-list.neg::-webkit-scrollbar-thumb { background: rgba(248,81,73,.35); border-radius: 2px; }
            .breakdown-item {
                display: flex; justify-content: space-between; align-items: center;
                padding: 6px 8px; margin: 2px 0; border-radius: 6px;
                font-size: 11px; font-weight: 500; border: 1px solid transparent;
                transition: background .12s, border-color .12s;
            }
            .breakdown-list.pos .breakdown-item:hover { background: rgba(63,185,80,.07); border-color: rgba(63,185,80,.15); }
            .breakdown-list.neg .breakdown-item:hover { background: rgba(248,81,73,.07); border-color: rgba(248,81,73,.15); }
            .breakdown-item .label { color: var(--text3); flex: 1; line-height: 1.35; }
            .breakdown-item .pts {
                font-family: 'JetBrains Mono', monospace; font-weight: 700;
                font-size: 10px; white-space: nowrap; margin-left: 8px;
            }
            .breakdown-item .pts.pos { color: var(--green); }
            .breakdown-item .pts.neg { color: var(--red); }
            .breakdown-empty { text-align: center; color: var(--text2); font-size: 10px; padding: 18px 4px; }

            /* ── Action buttons ── */
            .action-row { display: flex; gap: 8px; margin-bottom: 8px; }
            .btn {
                flex: 1; padding: 11px 16px; border: none; border-radius: var(--radius-sm);
                font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600;
                cursor: pointer; transition: all .15s; letter-spacing: -.1px;
                display: flex; align-items: center; justify-content: center; gap: 6px;
            }
            .btn:active  { transform: scale(.97); }
            .btn:disabled { opacity: 0.35; cursor: not-allowed; transform: none !important; }
            .btn-yes {
                background: var(--green); color: #0d1117;
                box-shadow: 0 1px 0 rgba(255,255,255,.15) inset;
            }
            .btn-yes:hover:not(:disabled) { background: #46d058; box-shadow: 0 4px 14px rgba(63,185,80,.4); }
            .btn-no {
                background: var(--red); color: #fff;
                box-shadow: 0 1px 0 rgba(255,255,255,.1) inset;
            }
            .btn-no:hover:not(:disabled) { background: #ff6158; box-shadow: 0 4px 14px rgba(248,81,73,.4); }
            .btn-next {
                background: var(--accent); color: #fff; width: 100%; margin-bottom: 8px;
                box-shadow: 0 1px 0 rgba(255,255,255,.12) inset;
            }
            .btn-next:hover:not(:disabled) { background: #388bfd; box-shadow: 0 4px 14px var(--accent-glow); }
            .btn-secondary {
                flex: 1; padding: 9px 12px; border: 1px solid var(--border2);
                border-radius: var(--radius-sm); background: var(--bg2);
                color: var(--text2); font-family: 'Inter', sans-serif; font-size: 11px;
                font-weight: 600; cursor: pointer; transition: all .15s;
                display: flex; align-items: center; justify-content: center; gap: 5px;
            }
            .btn-secondary:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }
            .btn-secondary:disabled { opacity: 0.4; cursor: not-allowed; }
            .kbd {
                font-family: 'JetBrains Mono', monospace; font-size: 9px;
                opacity: .45; padding: 1px 5px; border: 1px solid rgba(255,255,255,.12);
                border-radius: 4px; background: rgba(255,255,255,.05);
            }

            /* ── Divider ── */
            .screener-divider { height: 1px; background: var(--border); margin: 10px 0; }
        `;
        document.head.appendChild(style);
    }

    function buildPanel() {
        const existing = $('#screener-panel');
        if (existing) existing.remove();

        const panel = document.createElement('div');
        panel.id = 'screener-panel';
        panel.innerHTML = `
            <div id="screener-header">
                <div class="header-left">
                    <div class="header-icon">🔍</div>
                    <div>
                        <div class="header-title">Resume Screener</div>
                        <div class="header-sub">Amazon Delivery · Indeed</div>
                    </div>
                </div>
                <span class="screener-badge">v9.1</span>
            </div>
            <div class="screener-body">
                <div id="s-status" class="screener-status">Initializing…</div>
                <div class="score-card">
                    <div class="score-left">
                        <div class="score-label">Candidate Score</div>
                        <div id="s-score" class="score-value reject">—</div>
                        <span id="s-tier" class="score-tier reject">No Data</span>
                    </div>
                    <div class="score-right">
                        <div class="score-meta" id="s-meta">
                            Elite ≥ 100<br>
                            Review ≥ 70<br>
                            Maybe ≥ 40<br>
                            Reject &lt; 40
                        </div>
                    </div>
                </div>
                <div class="breakdown-grid">
                    <div class="breakdown-col">
                        <div class="breakdown-header pos"><span class="bh-dot"></span>Positives</div>
                        <div id="s-pos" class="breakdown-list pos"><div class="breakdown-empty">Analyzing…</div></div>
                    </div>
                    <div class="breakdown-col">
                        <div class="breakdown-header neg"><span class="bh-dot"></span>Negatives</div>
                        <div id="s-neg" class="breakdown-list neg"><div class="breakdown-empty">Analyzing…</div></div>
                    </div>
                </div>
                <div class="action-row">
                    <button id="s-yes" class="btn btn-yes">✓ Advance<span class="kbd">Y</span></button>
                    <button id="s-no"  class="btn btn-no">✗ Reject<span class="kbd">N</span></button>
                </div>
                <button id="s-next" class="btn btn-next">Next Candidate<span class="kbd">→</span></button>
                <div class="screener-divider"></div>
                <div class="action-row">
                    <button id="s-refresh"     class="btn-secondary">↻ Re-analyze</button>
                    <button id="s-auto-screen" class="btn-secondary">⚡ Auto-Screen</button>
                </div>
            </div>
        `;
        document.body.appendChild(panel);
        return panel;
    }

    // =====================================================================
    // SCREENER CONTROLLER
    // =====================================================================
    class Screener {
        constructor() {
            injectStyles();
            this.panel = buildPanel();
            this.extractor = null;
            this.lastResult = null;
            this.busy = false;
            this.autoScreenRunning = false;
            this.diag = new DiagnosticLogger();

            this._boundKeyHandler = this._onKeyDown.bind(this);
            this._boundMouseMove = null;
            this._boundMouseUp = null;

            this.bindEvents();
            this.makeDraggable();
            this.run();
        }

        _onKeyDown(e) {
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.isContentEditable) return;
            if (this.busy) return;
            if (e.key === 'y' || e.key === 'Y') this.clickYes();
            else if (e.key === 'n' || e.key === 'N') this.clickNo();
            else if (e.key === 'ArrowRight') this.nextCandidate();
            else if (e.key === 'r' || e.key === 'R') this.reanalyze();
            else if (e.key === 'd' || e.key === 'D') this.dumpDiag();
        }

        bindEvents() {
            $('#s-yes').addEventListener('click', () => this.clickYes());
            $('#s-no').addEventListener('click', () => this.clickNo());
            $('#s-next').addEventListener('click', () => this.nextCandidate());
            $('#s-refresh').addEventListener('click', () => this.reanalyze());
            $('#s-auto-screen').addEventListener('click', () => {
                if (this.autoScreenRunning) this.stopAutoScreen();
                else this.autoScreen();
            });
            document.addEventListener('keydown', this._boundKeyHandler);
        }

        makeDraggable() {
            const header = $('#screener-header');
            let drag = false, ox = 0, oy = 0, sx = 0, sy = 0;

            header.addEventListener('mousedown', e => {
                drag = true; sx = e.clientX - ox; sy = e.clientY - oy;
                header.style.cursor = 'grabbing';
            });
            this._boundMouseMove = e => {
                if (!drag) return; e.preventDefault();
                ox = e.clientX - sx; oy = e.clientY - sy;
                this.panel.style.transform = `translate(${ox}px, ${oy}px)`;
            };
            this._boundMouseUp = () => { if (drag) { drag = false; header.style.cursor = 'move'; } };

            document.addEventListener('mousemove', this._boundMouseMove);
            document.addEventListener('mouseup', this._boundMouseUp);
        }

        destroy() {
            document.removeEventListener('keydown', this._boundKeyHandler);
            if (this._boundMouseMove) document.removeEventListener('mousemove', this._boundMouseMove);
            if (this._boundMouseUp) document.removeEventListener('mouseup', this._boundMouseUp);
            this.panel?.remove();
        }

        setButtonsEnabled(enabled) {
            for (const id of ['#s-yes', '#s-no', '#s-next', '#s-refresh']) {
                const btn = $(id);
                if (btn) btn.disabled = !enabled;
            }
        }

        dumpDiag() {
            this.diag.dump(`DIAGNOSTICS — ${this.extractor?.candidateName || 'Unknown'}`);
        }

        async run(previousFingerprint = '') {
            if (this.busy) return null;
            this.busy = true;
            this.setButtonsEnabled(false);
            this.diag.clear();
            this.diag.log('PIPELINE', 'Starting analysis…');
            this.setStatus('Waiting for candidate data…', 'loading');

            const dataReady = await waitForNewCandidate(previousFingerprint);
            if (!dataReady) {
                this.setStatus('Timeout — no candidate data', 'err');
                this.diag.dump('TIMEOUT');
                this.busy = false; this.setButtonsEnabled(true);
                return null;
            }

            this.setStatus('Extracting…', 'loading');
            this.extractor = new Extractor(this.diag);
            this.extractor.extract();

            if (this.extractor.charCount < 100) {
                this.setStatus(`Insufficient data: ${this.extractor.charCount} chars`, 'err');
                this.diag.dump('INSUFFICIENT DATA');
                this.busy = false; this.setButtonsEnabled(true);
                return null;
            }

            this.setStatus('Analyzing…', 'loading');
            this.lastResult = analyzeText(this.extractor.text, this.extractor, this.diag);
            if (this.isRepeatApplicant()) {
                this.lastResult.neg['🔁 Repeat Applicant'] = -999;
                this.diag.log('SCORE', '🔁 REPEAT APPLICANT');
            }

            this.setStatus(`${this.extractor.method} · ${this.extractor.charCount.toLocaleString()} chars`, 'ok');
            this.render(this.lastResult);
            this.diag.dump(`DONE — ${this.extractor.candidateName || 'Unknown'} — Score: ${this.lastResult.score}`);

            this.busy = false; this.setButtonsEnabled(true);
            return this.lastResult;
        }

        async reanalyze() {
            if (this.busy) return;
            this.busy = true; this.setButtonsEnabled(false);
            this.diag.clear();
            this.setStatus('Re-analyzing…', 'loading');

            this.extractor = new Extractor(this.diag);
            this.extractor.extract();

            this.setStatus(
                `${this.extractor.method} · ${this.extractor.charCount.toLocaleString()} chars`,
                this.extractor.charCount > 200 ? 'ok' : 'err'
            );

            this.lastResult = analyzeText(this.extractor.text, this.extractor, this.diag);
            if (this.isRepeatApplicant()) this.lastResult.neg['🔁 Repeat Applicant'] = -999;

            this.render(this.lastResult);
            this.diag.dump(`RE-ANALYSIS — ${this.extractor.candidateName || 'Unknown'} — Score: ${this.lastResult.score}`);
            this.busy = false; this.setButtonsEnabled(true);
        }

        setStatus(msg, state) {
            const el = $('#s-status');
            if (!el) return;
            el.textContent = msg;
            el.className = 'screener-status' + (state ? ` ${state}` : '');
        }

        render(r) {
            const T = CONFIG.thresholds;
            const tier = r.score >= T.elite ? 'elite' : r.score >= T.review ? 'review' : r.score >= T.maybe ? 'maybe' : 'reject';
            const tierLabel = { elite: '⬆ Elite', review: '● Review', maybe: '▲ Maybe', reject: '✗ Reject' };
            const scoreEl = $('#s-score');
            scoreEl.textContent = r.score;
            scoreEl.className = 'score-value ' + tier;

            const tierEl = $('#s-tier');
            if (tierEl) { tierEl.textContent = tierLabel[tier]; tierEl.className = 'score-tier ' + tier; }

            const posEl = $('#s-pos');
            const negEl = $('#s-neg');
            const posKeys = Object.keys(r.pos);
            const negKeys = Object.keys(r.neg);

            posEl.innerHTML = posKeys.length
                ? posKeys.map(k => `<div class="breakdown-item"><span class="label">${this.escapeHtml(k)}</span><span class="pts pos">+${r.pos[k]}</span></div>`).join('')
                : '<div class="breakdown-empty">None found</div>';

            negEl.innerHTML = negKeys.length
                ? negKeys.map(k => `<div class="breakdown-item"><span class="label">${this.escapeHtml(k)}</span><span class="pts neg">${r.neg[k]}</span></div>`).join('')
                : '<div class="breakdown-empty">None found</div>';
        }

        escapeHtml(str) {
            const div = document.createElement('div');
            div.textContent = str;
            return div.innerHTML;
        }

        resetUI() {
            $('#s-score').textContent = '—';
            $('#s-score').className = 'score-value reject';
            const tierEl = $('#s-tier');
            if (tierEl) { tierEl.textContent = 'No Data'; tierEl.className = 'score-tier reject'; }
            $('#s-pos').innerHTML = '<div class="breakdown-empty">Analyzing…</div>';
            $('#s-neg').innerHTML = '<div class="breakdown-empty">Analyzing…</div>';
        }

        async clickYes() {
            if (this.busy) return;
            const btn = $('[data-testid="ApplicantSentiment-yes"]') || findIndeedButton('M9.55 14.947');
            if (btn) { btn.click(); await sleep(CONFIG.timing.clickActionDelay); await this.nextCandidate(); }
        }

        async clickNo() {
            if (this.busy) return;
            const btn = $('[data-testid="ApplicantSentiment-no"]') || findIndeedButton('M12 13.59');
            if (btn) { btn.click(); await sleep(CONFIG.timing.clickActionDelay); await this.nextCandidate(); }
        }

        async nextCandidate() {
            if (this.busy) return;
            const currentFingerprint = getCandidateFingerprint();
            this.resetUI();
            this.setStatus('Loading next candidate…', 'loading');

            const btn = findIndeedButton('M17.864 13.138') || $$('button').find(b => /next|→/i.test(b.textContent));
            if (!btn) { this.setStatus('No next button found', 'err'); return; }

            btn.click();
            await sleep(CONFIG.timing.unmountGrace);
            await this.run(currentFingerprint);
        }

        isRepeatApplicant() {
            if (this.extractor?.fiber?.found) {
                const count = this.extractor.fiber.getSubmissionCount();
                if (count > 1) return true;
            }
            for (const btn of $$('button')) {
                const text = btn.textContent || btn.innerText || '';
                if (/this candidate has applied to \d+ other jobs? on this account/i.test(text)) return true;
            }
            return false;
        }

        async autoScreen() {
            this.autoScreenRunning = true;
            const btn = $('#s-auto-screen');
            if (!btn) return;

            btn.textContent = '⏹ Stop';
            btn.style.background = 'var(--red)';
            btn.style.color = '#fff';
            btn.style.borderColor = 'var(--red-border)';

            let rejected = 0, total = 0, lastFingerprint = '', stuckCount = 0;
            const MAX_STUCK = 3;

            while (this.autoScreenRunning) {
                const currentFp = getCandidateFingerprint();
                if (currentFp && currentFp === lastFingerprint) {
                    stuckCount++;
                    if (stuckCount >= MAX_STUCK) { this.setStatus('Stuck — stopped', 'err'); break; }
                } else { stuckCount = 0; }
                lastFingerprint = currentFp;

                total++;
                const result = await this.run();
                if (!this.autoScreenRunning || !result) break;

                if (this.isRepeatApplicant()) {
                    const noBtn = $('[data-testid="ApplicantSentiment-no"]') || findIndeedButton('M12.0001 13.5909') || findIndeedButton('M12 13.59');
                    if (noBtn) noBtn.click();
                    rejected++;
                    btn.textContent = `⏹ ${rejected}/${total}`;
                    await sleep(CONFIG.timing.clickActionDelay);
                } else {
                    btn.textContent = `⏹ ${rejected}/${total}`;
                    break;
                }

                const fpBeforeNav = getCandidateFingerprint();
                const nextBtn = findIndeedButton('M17.864 13.138') || $$('button').find(b => /next|→/i.test(b.textContent));
                if (!nextBtn) break;

                this.resetUI();
                this.setStatus('Loading next…', 'loading');
                nextBtn.click();
                await sleep(CONFIG.timing.unmountGrace);
                if (!(await waitForNewCandidate(fpBeforeNav))) break;
            }

            this.stopAutoScreen();
        }

        stopAutoScreen() {
            this.autoScreenRunning = false;
            const btn = $('#s-auto-screen');
            if (!btn) return;
            btn.textContent = '⚡ Auto-Screen';
            btn.style.background = ''; btn.style.color = ''; btn.style.borderColor = '';
        }
    }

    // =====================================================================
    // INIT
    // =====================================================================
    function init() {
        if (window._screenerInstance91) return;

        for (let v = 7; v <= 9; v++) {
            const inst = window[`_screenerInstance${v}`];
            if (inst && typeof inst.destroy === 'function') inst.destroy();
            delete window[`_screenerInstance${v}`];
        }

        let created = false;
        const container = $('#candidateProfileContainer');
        if (container && (container.innerText || '').length > 100) {
            created = true;
            window._screenerInstance91 = new Screener();
            return;
        }

        const observer = new MutationObserver(() => {
            if (created) return;
            const c = $('#candidateProfileContainer');
            if (c && (c.innerText || '').length > 100) {
                created = true; observer.disconnect();
                window._screenerInstance91 = new Screener();
            }
        });
        observer.observe(document.body, { childList: true, subtree: true });

        setTimeout(() => {
            observer.disconnect();
            if (!created && !window._screenerInstance91) {
                created = true;
                window._screenerInstance91 = new Screener();
            }
        }, 4000);
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
})();

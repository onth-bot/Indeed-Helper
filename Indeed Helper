    }

    // =====================================================================
    // REACT FIBER EXTRACTION
    // =====================================================================
    class FiberExtractor {
        constructor(diag) {
            this.fragmentData = null;
            this.profile = null;
            this.talentRep = null;
            this.found = false;
            this.diag = diag;
        }

        findFragmentData(obj, depth = 0, visited = new WeakSet()) {
            if (depth > CONFIG.fiber.maxDepth || !obj || typeof obj !== 'object') return null;
            try { if (visited.has(obj)) return null; visited.add(obj); } catch (e) { return null; }

            if (obj.fragmentData && typeof obj.fragmentData === 'object' &&
                obj.fragmentData.__typename === 'CandidateSubmission') {
                return obj.fragmentData;
            }
            if (obj.memoizedProps) {
                const fd = obj.memoizedProps.fragmentData;
                if (fd && typeof fd === 'object' && fd.__typename === 'CandidateSubmission') {
                    return fd;
                }
            }
            for (const key of ['child', 'sibling']) {
                if (obj[key]) {
                    const result = this.findFragmentData(obj[key], depth + 1, visited);
                    if (result) return result;
                }
            }
            return null;
        }

        extract() {
            this.found = false;
            this.fragmentData = null;
            this.profile = null;
            this.talentRep = null;

            const targets = [
                '#candidateProfileContainer',
                '[data-testid="candidate-review-page"]',
                '[data-testid="namePlate"]',
            ];

            for (const sel of targets) {
                const el = $(sel);
                if (!el) { this.diag.log('FIBER', `Target ${sel}: NOT FOUND`); continue; }
                const fk = Object.keys(el).find(k =>
                    k.startsWith('__reactFiber') || k.startsWith('__reactProps')
                );
                if (!fk) { this.diag.log('FIBER', `Target ${sel}: no React fiber key`); continue; }
                this.diag.log('FIBER', `Target ${sel}: found fiber key "${fk.substring(0, 30)}…"`);

                this.fragmentData = this.findFragmentData(el[fk]);
                if (this.fragmentData) {
                    this.diag.log('FIBER', `✓ Found fragmentData via ${sel}`, {
                        typename: this.fragmentData.__typename,
                        hasData: !!this.fragmentData.data,
                        hasTalentRep: !!this.fragmentData.talentRepresentation,
                    });
                    break;
                } else {
                    this.diag.log('FIBER', `Target ${sel}: fiber key found but NO fragmentData`);
                }
            }

            if (!this.fragmentData) {
                this.diag.log('FIBER', 'Trying broad scan…');
                let scanned = 0;
                for (const el of document.querySelectorAll('div, section, main')) {
                    if (scanned++ > CONFIG.fiber.maxElements) break;
                    const fk = Object.keys(el).find(k => k.startsWith('__reactFiber'));
                    if (!fk) continue;
                    this.fragmentData = this.findFragmentData(el[fk]);
                    if (this.fragmentData) {
                        this.diag.log('FIBER', `✓ Found fragmentData via broad scan (element #${scanned})`);
                        break;
                    }
                }
                if (!this.fragmentData) {
                    this.diag.log('FIBER', `✗ Broad scan checked ${scanned} elements — no fragmentData`);
                }
            }

            if (!this.fragmentData) {
                this.diag.log('FIBER', '✗ FIBER EXTRACTION FAILED');
                return this;
            }

            this.found = true;
            const data = this.fragmentData.data || this.fragmentData;
            this.profile = data.profile || null;
            this.talentRep = this.fragmentData.talentRepresentation || null;

            this.diag.log('FIBER', `Profile name: ${this.getName() || 'null'}`);
            this.diag.log('FIBER', `TalentRep dataSource: ${this.talentRep?.dataSource || 'null'}`);
            this.diag.log('FIBER', `Experience: ${this.getExperience().length}, Education: ${this.getEducation().length}, Skills: ${this.getSkills().length}`);
            this.diag.log('FIBER', `Submissions: ${this.getSubmissionCount()}`);

            if (this.getExperience().length > 0) {
                this.diag.log('FIBER', 'Experience entries:', this.getExperience().map(e => ({
                    title: e.title || e.jobTitle,
                    company: e.company || e.employer,
                    dateRange: e.dateRange,
                })));
            }

            return this;
        }

        getName() { return this.profile?.name?.displayName || null; }
        getLocation() { return this.profile?.location?.location || null; }
        hasStructuredResume() {
            if (!this.talentRep || this.talentRep.dataSource === 'NONE') return false;
            return (this.talentRep.experience?.length > 0) ||
                   (this.talentRep.education?.length > 0) ||
                   (this.talentRep.skills?.length > 0);
        }
        getExperience() { return this.talentRep?.experience || []; }
        getEducation()  { return this.talentRep?.education || []; }
        getSkills()     { return this.talentRep?.skills || []; }
        getMilitary()   { return this.talentRep?.militaryService || []; }
        getSubmissionCount() {
            const subs = this.fragmentData?.data?.candidateIdentity?.candidate?.submissionsConnection?.submissions;
            return Array.isArray(subs) ? subs.length : 0;
        }
    }

    // =====================================================================
    // PDF TEXT EXTRACTOR
    // =====================================================================
    class PDFExtractor {
        constructor(diag) { this.diag = diag; }

        positionReconstruct(pdfView) {
            const spans = pdfView.querySelectorAll('span');
            const items = [];

            for (const span of spans) {
                const t = (span.textContent || '').trim();
                if (!t) continue;
                if (span.offsetWidth === 0 && span.offsetHeight === 0) continue;

                let top = 0, left = 0, el = span;
                while (el && el !== pdfView) {
                    top += el.offsetTop;
                    left += el.offsetLeft;
                    el = el.offsetParent;
                }
                items.push({ text: t, top, left });
            }

            this.diag.log('PDF', `Position reconstruct: ${spans.length} spans → ${items.length} visible`);
            if (items.length === 0) return '';

            items.sort((a, b) => a.top - b.top || a.left - b.left);

            const lines = [];
            let currentLine = [items[0]];
            for (let i = 1; i < items.length; i++) {
                if (Math.abs(items[i].top - currentLine[0].top) <= 5) {
                    currentLine.push(items[i]);
                } else {
                    currentLine.sort((a, b) => a.left - b.left);
                    lines.push(currentLine.map(s => s.text).join(' '));
                    currentLine = [items[i]];
                }
            }
            if (currentLine.length) {
                currentLine.sort((a, b) => a.left - b.left);
                lines.push(currentLine.map(s => s.text).join(' '));
            }

            const result = lines.join('\n');
            this.diag.log('PDF', `Position result: ${lines.length} lines, ${result.length} chars`);
            this.diag.log('PDF', `Preview:\n${result.substring(0, 500)}…`);
            return result;
        }

        joinLines(text) {
            return text.split('\n').map(l => l.trim()).filter(l => l).join(' ');
        }
    }

    // =====================================================================
    // COMBINED EXTRACTOR
    // =====================================================================
    class Extractor {
        constructor(diag) {
            this.diag = diag;
            this.fiber = new FiberExtractor(diag);
            this.pdf = new PDFExtractor(diag);
            this.text = '';
            this.method = 'none';
            this.charCount = 0;
            this.candidateName = null;
            this.hasFiberStructured = false;
        }

        extract() {
            const sources = [];

            this.fiber.extract();

            if (this.fiber.found) this.candidateName = this.fiber.getName();
            if (!this.candidateName) {
                const nameEl = $('[data-testid="name-plate-name-item"]') ||
                              $('[data-testid="candidate-name"]') || $('h1');
                if (nameEl) this.candidateName = (nameEl.textContent || '').trim() || null;
            }
            this.diag.log('EXTRACT', `Candidate name: ${this.candidateName || 'UNKNOWN'}`);

            this.hasFiberStructured = this.fiber.hasStructuredResume();
            this.diag.log('EXTRACT', `Has structured resume: ${this.hasFiberStructured}`);

            if (this.hasFiberStructured) {
                const fiberText = this.buildFromFiber();
                this.diag.log('EXTRACT', `Fiber text: ${fiberText.length} chars`);
                if (fiberText.length > 100) {
                    sources.push({ text: fiberText, method: 'Fiber', chars: fiberText.length });
                }
            }

            const container = $('#candidateProfileContainer');
            if (container) {
                const raw = container.innerText || '';
                this.diag.log('EXTRACT', `Container innerText: ${raw.length} chars`);
                if (raw.length > 200) {
                    sources.push({ text: raw, method: 'Container', chars: raw.length });
                }
            }

            if (!this.hasFiberStructured) {
                const pdfView = $('[data-testid="pdf-resume-view"]');
                if (pdfView) {
                    this.diag.log('EXTRACT', 'PDF view found');
                    const posText = this.pdf.positionReconstruct(pdfView);
                    if (posText.length > 200) sources.push({ text: posText, method: 'Position', chars: posText.length });
                    const joined = this.pdf.joinLines(pdfView.innerText || '');
                    if (joined.length > 200) sources.push({ text: joined, method: 'JoinLines', chars: joined.length });
                }
            }

            if (sources.length === 0) {
                this.diag.log('EXTRACT', 'Using TreeWalker fallback');
                const root = container || document.body;
                const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
                    acceptNode: n => {
                        const tag = n.parentElement?.tagName;
                        if (tag === 'SCRIPT' || tag === 'STYLE' || tag === 'NOSCRIPT') return NodeFilter.FILTER_REJECT;
                        return n.textContent.trim() ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
                    }
                });
                const parts = [];
                let node;
                while ((node = walker.nextNode())) { const t = node.textContent.trim(); if (t) parts.push(t); }
                const joined = parts.join(' ');
                if (joined.length > 100) sources.push({ text: joined, method: 'TreeWalker', chars: joined.length });
            }

            this.diag.log('EXTRACT', `Sources: ${sources.length} → [${sources.map(s => `${s.method}(${s.chars})`).join(', ')}]`);

            if (sources.length === 0) {
                this.text = ''; this.method = 'Insufficient'; this.charCount = 0;
                return '';
            }

            const merged = this.mergeSources(sources);
            this.text = merged.text;
            this.method = merged.methods;
            this.charCount = merged.text.length;

            console.log(`%c📄 Extraction [${this.method}]: ${this.charCount.toLocaleString()} chars`, 'color:#6366f1');
            return this.text;
        }

        mergeSources(sources) {
            if (sources.length === 1) return { text: sources[0].text, methods: sources[0].method };

            const dateRegex = /\d{4}\s*(?:[-–—~]|\s+to\s+)\s*(?:\d{4}|present|current|currently)/gi;
            const scored = sources.map(s => ({ ...s, dateCount: (s.text.match(dateRegex) || []).length }));
            scored.sort((a, b) => b.dateCount - a.dateCount || b.chars - a.chars);

            this.diag.log('MERGE', `Ranking: ${scored.map(s => `${s.method}(dates:${s.dateCount})`).join(' > ')}`);

            const seen = new Set();
            const allSentences = [];
            for (const source of scored) {
                const chunks = source.text.split(/[\n.!?]+/).map(c => c.trim()).filter(c => c.length > 10);
                for (const chunk of chunks) {
                    const norm = chunk.toLowerCase().replace(/\s+/g, ' ');
                    const key = norm.substring(0, 120) + '|' + norm.length;
                    if (!seen.has(key)) { seen.add(key); allSentences.push(chunk); }
                }
            }

            return { text: allSentences.join('\n'), methods: [...new Set(scored.map(s => s.method))].join('+') };
        }

        buildFromFiber() {
            const parts = [];
            const tr = this.fiber.talentRep;

            if (tr.summary) parts.push(tr.summary);
            if (tr.headline) parts.push(tr.headline);

            if (tr.experience?.length) {
                parts.push('EXPERIENCE');
                for (const exp of tr.experience) {
                    const title = exp.title || exp.jobTitle || '';
                    const company = exp.company || exp.employer || '';
                    const desc = exp.description || '';
                    let startStr = '', endStr = '';

                    if (exp.dateRange) {
                        const dr = exp.dateRange;
                        if (dr.fromDate) {
                            const m = dr.fromDate.month || '', y = dr.fromDate.year || '';
                            startStr = m && y ? `${m.charAt(0)}${m.slice(1).toLowerCase()} ${y}` : String(y);
                        }
                        if (dr.toDate) {
                            const m = dr.toDate.month || '', y = dr.toDate.year || '';
                            endStr = m && y ? `${m.charAt(0)}${m.slice(1).toLowerCase()} ${y}` : String(y);
                        }
                        if (dr.__typename === 'TalentRepresentationDateRangeCurrent' || !dr.toDate) endStr = endStr || 'Present';
                    } else {
                        startStr = exp.startDate || exp.start || '';
                        endStr = exp.endDate || exp.end || '';
                        if (!endStr && exp.currentlyWorking) endStr = 'Present';
                    }

                    const loc = exp.location?.city ? `${exp.location.city}, ${exp.location.state || exp.location.region || ''}` : '';
                    parts.push(`${title} at ${company} ${startStr} - ${endStr} ${loc}`.trim());
                    if (desc) parts.push(desc);
                }
            }

            if (tr.education?.length) {
                parts.push('EDUCATION');
                for (const edu of tr.education) {
                    const school = edu.school || edu.institution || edu.name || '';
                    const degree = edu.degree || edu.field || '';
                    let yearStr = '';
                    if (edu.dateRange?.fromDate?.year) {
                        yearStr = String(edu.dateRange.fromDate.year);
                        if (edu.dateRange.toDate?.year) yearStr += ' - ' + edu.dateRange.toDate.year;
                    } else { yearStr = edu.graduationDate || edu.endDate || edu.year || ''; }
                    parts.push(`${degree} ${school} ${yearStr}`.trim());
                }
            }

            if (tr.skills?.length) {
                parts.push('SKILLS');
                parts.push(tr.skills.map(s => typeof s === 'string' ? s : s.name || s.skill || s.label || '').filter(Boolean).join(', '));
            }

            if (tr.militaryService?.length) {
                parts.push('MILITARY');
                for (const mil of tr.militaryService) {
                    parts.push(`${mil.branch || mil.service || ''} ${mil.rank || ''}`.trim() || JSON.stringify(mil));
                }
            }

            if (tr.certifications?.length) {
                parts.push('CERTIFICATIONS');
                parts.push(tr.certifications.map(c => typeof c === 'string' ? c : c.name || c.title || '').filter(Boolean).join(', '));
            }

            return parts.join('\n');
        }
    }

    // =====================================================================
    // ANALYZER
    // =====================================================================
    function analyzeText(rawText, extractor, diag) {
        const S = CONFIG.scores;
        const result = { score: 0, pos: {}, neg: {}, debug: {} };

        const text = rawText.replace(/applied\s+to:\s*[^\n]+/gi, '').replace(/accepts?\s+push[^\n]*/gi, '');
        const lower = text.toLowerCase();

        if (lower.length < 100) {
            result.neg['⚠️ Insufficient Data'] = 0;
            diag.log('ANALYZE', '✗ Insufficient text');
            return result;
        }

        const add = (label, pts, trigger = '') => {
            result.score += pts;
            if (pts >= 0) result.pos[label] = pts;
            else result.neg[label] = pts;
            const msg = `${pts >= 0 ? '✅' : '🚩'} ${label}: ${pts > 0 ? '+' : ''}${pts}${trigger ? ` ← "${trigger}"` : ''}`;
            console.log(msg);
            diag.log('SCORE', msg);
        };

        console.log('%c═══ RESUME ANALYSIS v9.1 ═══', 'font-weight:bold;color:#6366f1;font-size:13px');

        // Name check
        const candidateName = extractor?.candidateName || '';
        if (candidateName) {
            const nameParts = candidateName.split(/\s+/).filter(Boolean);
            if (nameParts.length > 0 && nameParts[nameParts.length - 1].toLowerCase() === 'singh') {
                add('Last Name: Singh', S.lastNameSingh, candidateName);
            }
        }

        // Amazon & Delivery
        const amazonMatch = lower.match(KW.amazon);
        if (amazonMatch) add('Amazon Delivery', S.amazonExperience, amazonMatch[0]);
        const deliveryMatch = lower.match(KW.delivery);
        if (!amazonMatch && deliveryMatch) add('Delivery Experience', S.deliveryExperience, deliveryMatch[0]);

        // Keyword checks
        const checks = [
            [KW.cleanDriving,   'Clean Driving Record',  S.cleanDrivingRecord],
            [KW.physicalWork,   'Physical Work Exp',      S.physicalActiveWork],
            [KW.military,       'Military Background',    S.militaryExperience],
            [KW.skills,         'Relevant Skills',        S.relevantSkills],
            [KW.weekendAvail,   'Weekend Availability',   S.weekendAvailability],
            [KW.stationaryJobs, 'Office/Stationary Job',  S.stationaryJob],
            [KW.criminal,       'Criminal Record',        S.criminalRecord],
            [KW.accidents,      'Accidents Mentioned',    S.accidentsMentioned],
            [KW.overqualified,  'Overqualified',          S.overqualified],
            [KW.unreliable,     'Temporary/Short-term',   S.unreliableLanguage],
        ];
        for (const [regex, label, pts] of checks) {
            const match = lower.match(regex);
            if (match) add(label, pts, match[0]);
        }

        // Truck driving
        const workOnlyText = lower
            .replace(/certifications?\s*(?:&|and)?\s*licenses?[\s\S]{0,500}?(?=experience|education|skills|work|summary|objective|$)/gi, '')
            .replace(/licenses?\s*(?:&|and)?\s*certifications?[\s\S]{0,500}?(?=experience|education|skills|work|summary|objective|$)/gi, '');
        const truckMatch = workOnlyText.match(KW.truckDriving);
        if (truckMatch) add('Truck Driving/CDL', S.truckDrivingCDL, truckMatch[0]);

        // Security guard
        let securityJobCount = 0, securitySource = 'none';
        if (extractor?.fiber?.hasStructuredResume()) {
            for (const exp of extractor.fiber.getExperience()) {
                if (KW.securityGuard.test((exp.title || exp.jobTitle || '').toLowerCase())) securityJobCount++;
            }
            if (securityJobCount > 0) securitySource = 'fiber';
        }
        if (securityJobCount === 0 && !extractor?.fiber?.hasStructuredResume()) {
            const titlePatterns = [
                /(?:security\s*guard|security\s*officer|patrol\s*(?:security|officer|guard)|armed\s*guard|unarmed\s*guard|loss\s*prevention)\s*[·•\-–—at]+\s*\w/gi,
                /^(?:security\s*guard|security\s*officer|patrol\s*security\s*guard)/gim,
            ];
            const seen = new Set();
            for (const pattern of titlePatterns) {
                pattern.lastIndex = 0;
                let m;
                while ((m = pattern.exec(lower)) !== null) {
                    const posKey = Math.round(m.index / 50);
                    if (!seen.has(posKey)) { seen.add(posKey); securityJobCount++; }
                }
            }
            if (securityJobCount === 0 && KW.securityGuard.test(lower)) securityJobCount = 1;
            if (securityJobCount > 0) securitySource = 'text';
        }
        if (securityJobCount > 0) {
            add(`Security Guard (×${securityJobCount})`, securityJobCount * S.securityGuard, `${securityJobCount} jobs [${securitySource}]`);
        }

        // Resume quality
        const quality = assessQuality(rawText, extractor?.hasFiberStructured || false);
        diag.log('ANALYZE', `Resume quality: ${quality}`);
        if (quality === 'basic') add('Poor/Basic Resume', S.basicResume);

        // HS grad year
        const hsYear = extractHSGradYear(text, diag);
        if (hsYear > 0) {
            diag.log('ANALYZE', `HS Grad year: ${hsYear}`);
            if (hsYear >= 2020)      add('HS Grad 2020+',       S.hsGrad2020Plus);
            else if (hsYear >= 2014) add('HS Grad 2014-2019',   S.hsGrad2014to2019);
            else if (hsYear >= 2010) add('HS Grad 2010-2013',   S.hsGrad2010to2013);
            else                     add('HS Grad Before 2010',  S.hsGradBefore2010);
        }

        // Work history
        const wh = analyzeWorkHistory(text, diag);
        result.debug.workHistory = wh;

        console.log('%c📅 WORK HISTORY', 'color:#22c55e;font-weight:bold');
        console.log(`   Earliest: ${wh.earliest > 0 ? wh.earliest : 'NONE'}, Jobs: ${wh.count}, Stable: ${wh.stable ? 'YES' : 'NO'}`);
        if (wh.allJobs.length > 0) {
            wh.allJobs.forEach((j, i) => console.log(`      ${i + 1}. ${j.start}-${j.end} (${j.duration.toFixed(1)}yr)`));
        }

        if (wh.earliest > 0) {
            if (wh.earliest >= 2020)      add('Started 2020+',       S.recentWorkHistory2020);
            else if (wh.earliest >= 2015) add('Started 2015-2019',   S.recentWorkHistory2015);
            else if (wh.earliest >= 2010) add('Started 2010-2014',   S.workHistory2010to2014);
            else                          add('Started Before 2010',  S.veryOldWorkHistory);
        }

        if (wh.stable)             add('Job Stability', S.jobStability);
        else if (wh.extremeHopper) add('Extreme Job Hopping', S.extremeJobHopping, wh.hopperDetails);
        else if (wh.severeHopper)  add('Severe Job Hopping', S.severeJobHopping, wh.hopperDetails);
        else if (wh.hopper)        add('Job Hopping', S.jobHopping, wh.hopperDetails);

        console.log(`%c═══ SCORE: ${result.score} ═══`, 'font-weight:bold;font-size:14px;color:' +
            (result.score >= 100 ? '#22c55e' : result.score >= 70 ? '#eab308' : '#ef4444'));

        return result;
    }

    // =====================================================================
    // WORK HISTORY
    // =====================================================================
    function analyzeWorkHistory(fullText, diag) {
        const parser = new DateParser();
        let workText = fullText.toLowerCase();

        const eduHeaders = /\b(?:education(?:\s+and\s+training)?|academic\s+background)\b/gi;
        const sectionHeaders = /\b(?:experience|work\s+history|employment|professional|skills|certifications?|summary|objective|projects?|volunteer|references?)\b/gi;

        const eduPositions = [];
        let m;
        while ((m = eduHeaders.exec(workText)) !== null) eduPositions.push(m.index);

        for (const eduStart of eduPositions.reverse()) {
            sectionHeaders.lastIndex = eduStart + 10;
            const nextSection = sectionHeaders.exec(workText);
            const eduEnd = nextSection ? nextSection.index : Math.min(eduStart + 1500, workText.length);
            workText = workText.substring(0, eduStart) + ' '.repeat(eduEnd - eduStart) + workText.substring(eduEnd);
        }

        workText = workText.replace(/high\s+school[^\n]{0,150}?(?:\d{4}|diploma|ged)/gi, ' ');
        workText = workText.replace(/(?:attended|graduated|diploma|ged|degree)[^\n]{0,150}?\d{4}/gi, ' ');
        workText = workText.replace(/\buniversity\b[^\n]{0,150}?\d{4}/gi, ' ');
        workText = workText.replace(/\bcollege\b[^\n]{0,150}?\d{4}/gi, ' ');

        const allDates = parser.extractAllDates(workText);
        diag.log('DATES', `Raw dates: ${allDates.length}`, allDates.map(d => ({ match: d.match, start: d.start, end: d.end })));
        diag.log('DATES', `Work text preview:\n${workText.trim().substring(0, 800)}…`);

        const currentYear = new Date().getFullYear();
        const workDates = allDates.filter(d => {
            if (d.start < 1990 || d.start > currentYear) return false;
            if (d.end < d.start || d.end > currentYear) return false;
            if ((d.end - d.start) < 0.08 && d.end !== currentYear) return false;
            return true;
        });

        diag.log('DATES', `Filtered: ${workDates.length}`, workDates.map(d => `${d.start}-${d.end} "${d.match}"`));

        if (workDates.length === 0) {
            diag.log('DATES', '✗ NO work dates found');
            return { earliest: 0, stable: false, hopper: false, severeHopper: false, extremeHopper: false, count: 0, allJobs: [], hopperDetails: '' };
        }

        const earliest = Math.min(...workDates.map(d => d.start));
        const jobs = workDates.map(d => ({ start: d.start, end: d.end, duration: d.end - d.start, match: d.match }));

        const stable = jobs.some(j => j.duration >= 2);
        const under6Months = jobs.filter(j => j.duration < 0.5).length;
        const under1Year   = jobs.filter(j => j.duration < 1).length;
        const under2Years  = jobs.filter(j => j.duration < 2).length;

        const extremeHopper = under6Months >= 3;
        const severeHopper  = !extremeHopper && (under6Months >= 2 || under1Year >= 4);
        const hopper        = !extremeHopper && !severeHopper && !stable && (under1Year >= 3 || under2Years >= 5);

        let hopperDetails = '';
        if (extremeHopper)     hopperDetails = `${under6Months} jobs < 6mo`;
        else if (severeHopper) hopperDetails = `${under6Months} < 6mo, ${under1Year} < 1yr`;
        else if (hopper)       hopperDetails = `${under1Year} < 1yr, ${under2Years} < 2yr`;

        return { earliest, stable, hopper, severeHopper, extremeHopper, count: jobs.length, allJobs: jobs, hopperDetails };
    }

    // =====================================================================
    // HS GRADUATION YEAR
    // =====================================================================
    function extractHSGradYear(text, diag) {
        const eduSectionMatch = text.match(
            /(?:education(?:\s+and\s+training)?|academic\s+background)[\s\S]{0,800}?(?=(?:experience|work\s+history|employment|professional|skills|certifications?|summary|objective|$))/i
        );
        const eduText = eduSectionMatch ? eduSectionMatch[0] : '';
        diag.log('HS_GRAD', `Education section: ${eduText.length > 0 ? 'YES' : 'NO'} (${eduText.length} chars)`);

        const searchTexts = eduText ? [eduText, text] : [text];
        for (const searchText of searchTexts) {
            const patterns = [
                /(?:high\s+school|hs|secondary\s+school)[^0-9]{0,100}?(\d{4})/gi,
                /(?:high\s+school|hs|diploma)[^0-9]{0,50}?\d{1,2}\/(\d{4})/gi,
                /ged[^0-9]{0,50}?(\d{4})/gi,
            ];
            for (const p of patterns) {
                p.lastIndex = 0;
                let m;
                while ((m = p.exec(searchText)) !== null) {
                    const y = parseInt(m[1]);
                    if (y >= 1980 && y <= 2030) { diag.log('HS_GRAD', `Found ${y}: "${m[0]}"`); return y; }
                }
            }

            const hsPatterns = [
                /(?:high\s+school|cambridge|diploma|ged)[\s\S]{0,200}?(\d{1,2})\/(\d{4})/gi,
                /(\d{1,2})\/(\d{4})[\s\S]{0,200}?(?:high\s+school|diploma|ged)/gi,
            ];
            for (const p of hsPatterns) {
                p.lastIndex = 0;
                let m;
                while ((m = p.exec(searchText)) !== null) {
                    const y = parseInt(m[2]);
                    if (y >= 1980 && y <= 2030) { diag.log('HS_GRAD', `Found ${y} via MM/YYYY`); return y; }
                }
            }

            if (searchText === eduText && eduText.length > 0) {
                const years = (eduText.match(/\b(19\d{2}|20\d{2})\b/g) || [])
                    .map(Number).filter(y => y >= 1980 && y <= 2030).sort((a, b) => b - a);
                if (years.length > 0) { diag.log('HS_GRAD', `Found ${years[0]} from edu section`); return years[0]; }
                break;
            }
        }
        diag.log('HS_GRAD', 'No HS year found');
        return 0;
    }

    // =====================================================================
    // RESUME QUALITY
    // =====================================================================
    function assessQuality(text, isFiberOnly = false) {
        let q = 0;
        const len = text.length;
        const sections = (text.match(/\b(experience|education|skills|summary|objective|certifications?)\b/gi) || []).length;
        const dateRanges = (text.match(/\d{4}\s*(?:[-–—~]|\s+to\s+)\s*(?:\d{4}|present|current|currently)/gi) || []).length;
        const actionVerbs = (text.match(/\b(managed|developed|created|led|coordinated|implemented|organized|improved|achieved|delivered|maintained|operated|assisted|trained|resolved|processed|handled|performed)\b/gi) || []).length;

        if (sections >= 3) q += 2; else if (sections < 2) q -= 2;
        if (dateRanges >= 2) q += 1; else if (dateRanges === 0) q -= 1;
        if (actionVerbs >= 4) q += 1;

        if (!isFiberOnly) {
            const lines = text.split('\n').filter(l => l.trim()).length;
            const bullets = (text.match(/[•\-*]\s+/g) || []).length;
            if (bullets >= 5) q += 1;
            if (len >= 1500) q += 2; else if (len < 400) q -= 2;
            if (lines < 15 && len > 500) q -= 2;
            if (!/[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}/i.test(text)) q -= 1;
        } else {
            if (len >= 500) q += 1;
            if (dateRanges >= 3) q += 1;
        }

        return q >= 5 ? 'good' : q >= 1 ? 'average' : 'basic';
    }


    function waitFor(conditionFn, { interval = 150, timeout = 5000 } = {}) {
        return new Promise(resolve => {
            const start = Date.now();
            const check = () => {
                try {
                    const result = conditionFn();
                    if (result) return resolve(result);
                } catch (e) { /* keep polling */ }
                if (Date.now() - start >= timeout) return resolve(null);
                setTimeout(check, interval);
            };
            check();
        });
    }

    function getCandidateFingerprint() {
        const nameEl = $('[data-testid="name-plate-name-item"]') ||
                       $('[data-testid="candidate-name"]');
        if (nameEl) {
            const name = (nameEl.textContent || '').trim();
            if (name.length > 1) return name;
        }
        const container = $('#candidateProfileContainer');
        if (container) {
            const text = (container.innerText || '').substring(0, 200).trim();
            if (text.length > 20) return text;
        }
        return '';
    }

    // Resolves as soon as the candidate container's text stops growing for
    // stabilityMs in a row (meaning all content has rendered), with a hard
    // safety ceiling of maxMs.  Returns true if stable, false on timeout.
    function waitForContentStable() {
        const { stabilityMs, stabilityPoll, stabilityMin, maxWait } = CONFIG.candidateLoad;
        return new Promise(resolve => {
            let lastLen = 0;
            let stableAt = Date.now();
            const deadline = Date.now() + maxWait;
            const check = () => {
                const container = $('#candidateProfileContainer');
                const len = container ? (container.innerText || '').length : 0;
                if (len !== lastLen) {
                    lastLen = len;
                    stableAt = Date.now();
                }
                if (len >= stabilityMin && Date.now() - stableAt >= stabilityMs) {
                    return resolve(true);
                }
                if (Date.now() >= deadline) return resolve(len >= stabilityMin);
                setTimeout(check, stabilityPoll);
            };
            check();
        });
    }

    async function waitForNewCandidate(previousFingerprint) {
        const { pollInterval, maxWait } = CONFIG.candidateLoad;

        // Phase 1 — wait for the DOM fingerprint to change (old candidate gone)
        if (previousFingerprint) {
            await waitFor(() => {
                const current = getCandidateFingerprint();
                return current && current !== previousFingerprint;
            }, { interval: pollInterval, timeout: maxWait / 2 });
        }

        // Phase 2 — wait for React fiber to attach (page is mounting)
        const ready = await waitFor(() => {
            const container = $('#candidateProfileContainer');
            if (!container) return false;
            const text = container.innerText || '';
            if (text.length < 80) return false;

            const targets = [
                '#candidateProfileContainer',
                '[data-testid="candidate-review-page"]',
                '[data-testid="namePlate"]',
            ];
            for (const sel of targets) {
                const el = $(sel);
                if (!el) continue;
                const fk = Object.keys(el).find(k =>
                    k.startsWith('__reactFiber') || k.startsWith('__reactProps')
                );
                if (fk) return true;
            }
            return text.length > 500;
        }, { interval: pollInterval, timeout: maxWait });

        if (!ready) return false;

        // Phase 3 — wait for content to fully stabilise (no fixed sleep)
        return waitForContentStable();
    }

